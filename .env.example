# Discord Bot Token
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Telegram Bot Token (from @BotFather for @opxero)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Channel mapping for message bridging
DISCORD_CHANNEL_ID=your_discord_channel_id_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Discord Webhook URL (Hawk webhook for #taskade channel)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Pushcut API Key (for taskade-agent widget updates)
PUSHCUT_API_KEY=your_pushcut_api_key_here
PUSHCUT_WIDGET_ID=taskade-agent

# Webhook server port for receiving external automations
WEBHOOK_SERVER_PORT=8080
